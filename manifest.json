{
  "manifest_version": 3,
  "name": "Desat",
  "version": "1.0",
  "description": "Right-click images or page to toggle desaturation for images and favicons, per-image, per-domain, or all at once.",
  "permissions": ["contextMenus", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Desat"
  }
}